{
  "_comment": "qumall admin 后台菜单路径映射表。基础功能: 通过 user_dropdown → 个人信息 → 基本信息 路径（个人信息 dropdown 项是 #/info/index）。其他 module: top_tab + sidebar。",
  "_actions": {
    "top_tab": "点击顶部 5 个 tab 之一 (运营/财务/IOT/充电桩/系统)",
    "sidebar": "点击左侧 sidebar menu item 的文字",
    "user_dropdown": "点击右上角用户头像区域 (huitong + ▼) 展开下拉，再点菜单项",
    "home": "点击顶栏 logo / home 图标回首页 (充电桩 tab 的首页)",
    "sub_link": "页面内的二级链接 / 按钮 (subfunction 匹配)"
  },

  "登录":           [{"act": "top_tab", "value": "登录"}],
  "首页":           [{"act": "home"}],

  "基础功能": [
    {"act": "navigate", "value": "https://admin.qumall.qushiyun.com/#/info/index"},
    {"act": "sub_link", "value": "{subfunction}"}
  ],

  "充电桩首页":     [{"act": "top_tab", "value": "充电桩"}],

