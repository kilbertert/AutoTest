{
  "name": "trendpower-shell",
  "displayName": "Trendpower Shell",
  "description": "VS Code shell that drives the trendpower ReAct agent for natural-language API/UI testing",
  "version": "2.0.0",
  "icon": "resources/icon.png",
  "publisher": "microsoft",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/AutoGenesis.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Testing"
  ],
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trendpower-shell",
          "title": "Trendpower",
          "icon": "resources/ai-robot-icon.svg"
        }
      ]
    },
    "views": {
      "trendpower-shell": [
        {
          "type": "webview",
          "id": "trendpower-shell.sidebar",
          "name": "Trendpower Sidebar",
          "icon": "resources/ai-robot-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "trendpower-shell.openSidebar",
        "title": "Open Trendpower Sidebar",
        "category": "Trendpower"
      },
      {
        "command": "trendpower-shell.runPrompt",
        "title": "Run Prompt in Trendpower",
        "category": "Trendpower"
      },
      {
        "command": "trendpower-shell.cancelRun",
        "title": "Cancel Running Prompt",
        "category": "Trendpower"
      }
    ],
    "keybindings": []
  },
  "main": "./out/src/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node scripts/compile.js",
    "compile-ts": "tsc -p ./",
    "watch": "npm run compile && tsc -watch -p ./",
    "package": "npm run compile && vsce package",
    "watch-tests": "tsc -p . --outDir out --watch",
    "pretest": "npm run compile",
    "format": "prettier --write \"src/**/*.{ts,js,json}\""
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.95.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vsce": "^1.87.0"
  }
}